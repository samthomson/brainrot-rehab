FROM node:22-bookworm-slim AS builder
WORKDIR /app
ARG VITE_DVM_PUBKEY
ARG VITE_RELAYS
ARG VITE_BLOSSOM_UPLOAD_URL
ENV VITE_DVM_PUBKEY=${VITE_DVM_PUBKEY}
ENV VITE_RELAYS=${VITE_RELAYS}
ENV VITE_BLOSSOM_UPLOAD_URL=${VITE_BLOSSOM_UPLOAD_URL}
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:22-bookworm-slim
WORKDIR /app
COPY --from=builder /app/dist ./dist
EXPOSE 3000
CMD ["npx", "serve", "-s", "dist", "-l", "3000"]
