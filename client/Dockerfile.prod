FROM node:22-bookworm-slim AS builder
WORKDIR /app
# Optional: pass at build time so prod client subscribes to the right DVM (e.g. --build-arg VITE_DVM_PUBKEY=hex64)
ARG VITE_DVM_PUBKEY
ENV VITE_DVM_PUBKEY=${VITE_DVM_PUBKEY}
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:22-bookworm-slim
WORKDIR /app
COPY --from=builder /app/dist ./dist
EXPOSE 3000
CMD ["npx", "serve", "-s", "dist", "-l", "3000"]
