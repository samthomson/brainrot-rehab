# DVM service: private key. Generate: openssl rand -hex 32
DVM_SECRET_KEY=your_hex_private_key_here
# Relay(s) the DVM subscribes to for job requests (comma-separated). Must match the relay(s) you enable in the app (Settings → DVM Relay Pool).
RELAYS=wss://relay.brainrot.rehab

# Client build: REQUIRED — set to DVM public key (from DVM logs after DVM starts).
# Without this, the client can't subscribe to DVM job status and jobs hang at "Waiting for DVM…"
VITE_DVM_PUBKEY=
